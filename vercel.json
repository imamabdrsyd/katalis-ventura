{
  "installCommand": "npm ci",
  "functions": {
    "app/api/**": {
      "regions": ["hnd1"],
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-olap",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/sync-ical",
      "schedule": "0 5 * * *"
    }
  ]
}
